    "@ai-sdk/openai": "^3.0.80",
    "@ai-sdk/openai-compatible": "^2.0.56",
    "@ai-sdk/xai": "^3.0.102",
    "@browser-ai/core": "^2.1.12",
    "@browser-ai/web-llm": "^2.1.7",
    "@mlc-ai/web-llm": "^0.2.84",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/node": "^22.9.0",
